features = op('null_features')

timbre_table = op('timbre_library')
bass_table = op('bass_library')
state = op('play_state')

audio_timbre_A = op('audiofile_timbre_A')
audio_timbre_B = op('audiofile_timbre_B')
audio_bass_A = op('audiofile_bass_A')
audio_bass_B = op('audiofile_bass_B')

fade_timbre_A = op('fade_timbre_A')
fade_timbre_B = op('fade_timbre_B')
fade_bass_A = op('fade_bass_A')
fade_bass_B = op('fade_bass_B')

brightness = float(features[0][0])
motion = float(features[1][0])

timbre_folder = "C:/Users/hauch/Desktop/CTC 26 SS/Final Touch Designer/Stock Resources/Audios/timbre/"
bass_folder = "C:/Users/hauch/Desktop/CTC 26 SS/Final Touch Designer/Stock Resources/Audios/bass/"


best_timbre = None
best_timbre_score = 999999

for i in range(1, timbre_table.numRows):
    filename = timbre_table[i, 0].val
    target_brightness = float(timbre_table[i, 1].val)

    score = abs(brightness - target_brightness)

    if score < best_timbre_score:
        best_timbre_score = score
        best_timbre = filename


best_bass = None
best_bass_score = 999999

for i in range(1, bass_table.numRows):
    filename = bass_table[i, 0].val
    target_motion = float(bass_table[i, 1].val)

    score = abs(motion - target_motion)

    if score < best_bass_score:
        best_bass_score = score
        best_bass = filename


timbre_active = state[1, 1].val
timbre_current = state[2, 1].val

if best_timbre is not None and best_timbre != timbre_current:
    timbre_path = timbre_folder + best_timbre

    if timbre_active == 'A':
        # Load new timbre into B
        audio_timbre_B.par.file = timbre_path

        # Fade A out, B in
        fade_timbre_A.par.value0 = 0
        fade_timbre_B.par.value0 = 1

        # Update state
        state[1, 1] = 'B'
        state[2, 1] = best_timbre

        print("Timbre crossfade A -> B:", best_timbre)

    else:
        # Load new timbre into A
        audio_timbre_A.par.file = timbre_path

        # Fade B out, A in
        fade_timbre_A.par.value0 = 1
        fade_timbre_B.par.value0 = 0

        # Update state
        state[1, 1] = 'A'
        state[2, 1] = best_timbre

        print("Timbre crossfade B -> A:", best_timbre)


bass_active = state[3, 1].val
bass_current = state[4, 1].val

if best_bass is not None and best_bass != bass_current:
    bass_path = bass_folder + best_bass

    if bass_active == 'A':
        # Load new bass into B
        audio_bass_B.par.file = bass_path

        # Fade A out, B in
        fade_bass_A.par.value0 = 0
        fade_bass_B.par.value0 = 1

        # Update state
        state[3, 1] = 'B'
        state[4, 1] = best_bass

        print("Bass crossfade A -> B:", best_bass)

    else:
        # Load new bass into A
        audio_bass_A.par.file = bass_path

        # Fade B out, A in
        fade_bass_A.par.value0 = 1
        fade_bass_B.par.value0 = 0

        # Update state
        state[3, 1] = 'A'
        state[4, 1] = best_bass

        print("Bass crossfade B -> A:", best_bass)

print("Brightness:", brightness, "Motion:", motion)
